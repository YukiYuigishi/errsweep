#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

run_step() {
  echo "[pre-commit] $*"
  "$@"
}

run_step golangci-lint run --fix ./...

# AI 生成コードの品質担保として test-all を必須実行する。
run_step make test-all

if ! git diff --quiet -- .; then
  echo "[pre-commit] working tree changed by checks. stage updates and commit again."
  git --no-pager status --short
  exit 1
fi
